{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/amazon-codepipeline-pipeline.json",
  "title": "Amazon CodePipeline Pipeline",
  "description": "Schema for an Amazon CodePipeline pipeline resource, representing a continuous delivery pipeline with stages and actions.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the pipeline.",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[A-Za-z0-9.@\\-_]+$"
    },
    "roleArn": {
      "type": "string",
      "description": "The ARN of the IAM service role that CodePipeline uses to perform actions.",
      "pattern": "^arn:aws:iam::[0-9]{12}:role/.+"
    },
    "artifactStore": {
      "type": "object",
      "description": "The S3 bucket used to store artifacts for the pipeline.",
      "required": ["type", "location"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["S3"],
          "description": "The type of the artifact store."
        },
        "location": {
          "type": "string",
          "description": "The S3 bucket used for storing the artifacts."
        },
        "encryptionKey": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "The ID used to identify the key."
            },
            "type": {
              "type": "string",
              "enum": ["KMS"],
              "description": "The type of encryption key."
            }
          }
        }
      }
    },
    "stages": {
      "type": "array",
      "description": "The stages in the pipeline.",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/StageDeclaration"
      }
    },
    "version": {
      "type": "integer",
      "description": "The version number of the pipeline.",
      "minimum": 1
    },
    "executionMode": {
      "type": "string",
      "description": "The method that the pipeline will use to handle multiple executions.",
      "enum": ["QUEUED", "SUPERSEDED", "PARALLEL"]
    },
    "pipelineType": {
      "type": "string",
      "description": "The pipeline type.",
      "enum": ["V1", "V2"]
    }
  },
  "required": ["name", "roleArn", "stages"],
  "$defs": {
    "StageDeclaration": {
      "type": "object",
      "description": "A stage in the pipeline.",
      "required": ["name", "actions"],
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the stage."
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": ["Schedule"]
              }
            }
          }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ActionDeclaration"
          }
        }
      }
    },
    "ActionDeclaration": {
      "type": "object",
      "description": "An action in a pipeline stage.",
      "required": ["name", "actionTypeId"],
      "properties": {
        "name": {
          "type": "string",
          "description": "The action name."
        },
        "actionTypeId": {
          "type": "object",
          "required": ["category", "owner", "provider", "version"],
          "properties": {
            "category": {
              "type": "string",
              "enum": ["Source", "Build", "Deploy", "Test", "Invoke", "Approval"]
            },
            "owner": {
              "type": "string",
              "enum": ["AWS", "ThirdParty", "Custom"]
            },
            "provider": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          }
        },
        "runOrder": {
          "type": "integer",
          "minimum": 1,
          "maximum": 999
        },
        "configuration": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "inputArtifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        },
        "outputArtifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        },
        "region": {
          "type": "string"
        }
      }
    }
  }
}
