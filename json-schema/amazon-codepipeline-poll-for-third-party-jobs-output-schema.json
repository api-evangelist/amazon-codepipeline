  "title": "PollForThirdPartyJobsOutput",
  "description": "Represents the output of a <code>PollForThirdPartyJobs</code> action.",
  "type": "object",
  "properties": {
    "jobs": {
      "allOf": [
        {
          "$ref": "#/components/schemas/ThirdPartyJobList"
